import static java.lang.System.in;

// 2. Implement the Prime class
class Prime {
    // The ... syntax (varargs) allows the method to accept any number of int arguments
    public void checkPrime(int... numbers) {
        for (int num : numbers) {
            if (isPrime(num)) {
                System.out.print(num + " ");
            }
        }
        System.out.println(); // New line after each set of checks
    }

    // Helper method to check if a number is prime
    private boolean isPrime(int n) {
        if (n < 2) {
            return false;
        }
        for (int i = 2; i <= (int) Math.sqrt(n); i++) {
            if (n % i == 0) {
                return false;
            }
        }
        return true;
    }
}

