Java Anagrams

static boolean isAnagram(String a, String b) {
        // 1. If lengths are different, they cannot be anagrams
        if (a.length() != b.length()) {
            return false;
        }

        // 2. Convert both strings to lowercase for case-insensitivity
        a = a.toLowerCase();
        b = b.toLowerCase();

        // 3. Create a frequency array for the 26 letters of the English alphabet
        int[] frequencies = new int[26];

        // 4. Traverse the strings and update frequencies
        for (int i = 0; i < a.length(); i++) {
            // For string 'a', increment the count at the character's index
            frequencies[a.charAt(i) - 'a']++;
            
            // For string 'b', decrement the count at the character's index
            frequencies[b.charAt(i) - 'a']--;
        }

        // 5. If the strings are anagrams, every value in the array must be 0
        for (int count : frequencies) {
            if (count != 0) {
                return false;
            }
        }

        return true;
    }



Java Substring Comparisons


    public static String getSmallestAndLargest(String s, int k) {
        // Initialize smallest and largest with the first substring of length k
        String currentSubstring = s.substring(0, k);
        String smallest = currentSubstring;
        String largest = currentSubstring;

        // Iterate through the string to find all substrings of length k
        // The loop runs until 'i <= s.length() - k' to ensure we don't go out of bounds
        for (int i = 1; i <= s.length() - k; i++) {
            currentSubstring = s.substring(i, i + k);
            
            // Compare currentSubstring with the current smallest
            if (currentSubstring.compareTo(smallest) < 0) {
                smallest = currentSubstring;
            }
            
            // Compare currentSubstring with the current largest
            if (currentSubstring.compareTo(largest) > 0) {
                largest = currentSubstring;
            }
        }

        return smallest + "\n" + largest;
    }

   
