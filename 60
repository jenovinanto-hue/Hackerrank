import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Read the number of lines
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();

        // Create a list to hold each line's list of integers
        ArrayList<ArrayList<Integer>> lines = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            int d = sc.nextInt(); // Number of integers in this line
            ArrayList<Integer> row = new ArrayList<>();
            for (int j = 0; j < d; j++) {
                row.add(sc.nextInt());
            }
            lines.add(row);
        }

        // Read the number of queries
        int q = sc.nextInt();
        for (int i = 0; i < q; i++) {
            int x = sc.nextInt(); // Line number (1-indexed)
            int y = sc.nextInt(); // Position number (1-indexed)

            // Convert to 0-indexed and check bounds
            // x-1 is the index for the outer list
            // y-1 is the index for the inner list
            if (x > 0 && x <= lines.size()) {
                ArrayList<Integer> currentRow = lines.get(x - 1);
                if (y > 0 && y <= currentRow.size()) {
                    System.out.println(currentRow.get(y - 1));
                } else {
                    System.out.println("ERROR!");
                }
            } else {
                System.out.println("ERROR!");
            }
        }

        sc.close();
    }
}


Java Subarray
import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        
        // Read the size of the array
        if (!scan.hasNextInt()) return;
        int n = scan.nextInt();
        int[] arr = new int[n];
        
        // Fill the array with values from STDIN
        for (int i = 0; i < n; i++) {
            arr[i] = scan.nextInt();
        }
        scan.close();
        
        int negativeSubarraysCount = 0;
        
        // Loop through each possible starting index
        for (int i = 0; i < n; i++) {
            int currentSum = 0;
            
            // Loop through each possible ending index starting from i
            for (int j = i; j < n; j++) {
                // Add the current element to the sum of the subarray [i...j]
                currentSum += arr[j];
                
                // If the sum is negative, increment the counter
                if (currentSum < 0) {
                    negativeSubarraysCount++;
                }
            }
        }
        
        // Print the final count
        System.out.println(negativeSubarraysCount);
    }
}

