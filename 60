import java.io.*;
import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String A = sc.next();
        String B = sc.next();
        int c = A.length();
        int d = B.length();
        
        System.out.println(c + d);
        
        if (A.compareTo(B) > 0) {
            System.out.println("Yes");
        } else {
            System.out.println("No");
        }
        
        System.out.println(capitalizeFirstLetter(A) + " " + capitalizeFirstLetter(B));
    }
    
    private static String capitalizeFirstLetter(String str) {
        if (str == null || str.isEmpty()) {
            return str; 
        }
        return Character.toUpperCase(str.charAt(0)) + str.substring(1);
    }
}

Java Regex

class MyRegex {
    /*
     * ([01]?\\d{1,2}|2[0-4]\\d|25[0-5]) 
     * [01]?\\d{1,2} matches 1 or 2 digits, and 3 digits starting with 0 or 1
     * 2[0-4]\\d matches numbers from 200 to 249
     * 25[0-5] matches numbers from 250 to 255
     * \\. matches the literal dot character
     */
    String octet = "([01]?\\d{1,2}|2[0-4]\\d|25[0-5])";
    
    // Concatenate the octet 4 times separated by dots
    // ^ and $ ensure the string is exactly an IP and nothing else
    public String pattern = "^" + octet + "\\." + octet + "\\." + octet + "\\." + octet + "$";
}
